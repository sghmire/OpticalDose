<UserControl x:Class="FilmAnalysis.AnalysisControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:FilmAnalysis"
             xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200">
    <Grid Background="{DynamicResource ApplicationBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar Controls -->
        <Border Grid.Column="0" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="0,0,1,0" Padding="15">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Dose Comparison" FontSize="18" Style="{StaticResource DosimetrySectionHeader}" Margin="0,0,0,20" />

                    <!-- Sources -->
                    <TextBlock Text="Data Sources" Style="{StaticResource DosimetrySectionHeader}" Margin="0,0,0,10" />
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ui:Button x:Name="SyncFilmButton" Content="Sync Film" Icon="{ui:SymbolIcon ArrowSync24}" HorizontalAlignment="Stretch" Margin="0,0,5,0" Click="SyncFilmButton_Click" Height="38" />
                        <ui:Button x:Name="SyncDicomButton" Grid.Column="1" Content="Sync DICOM" Icon="{ui:SymbolIcon CubeSync24}" HorizontalAlignment="Stretch" Click="SyncDicomButton_Click" Height="38" />
                    </Grid>
                    
                    <!-- ROI Selection -->
                    <TextBlock Text="Region of Interest" Style="{StaticResource DosimetrySectionHeader}" Margin="0,0,0,5" />
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:Button x:Name="SelectRoiButton" Content="Select ROI" Icon="{ui:SymbolIcon Crop24}" HorizontalAlignment="Stretch" Grid.Column="0" Margin="0,0,5,0" Click="SelectRoi_Click" IsEnabled="False" Height="38" />
                        <ui:Button x:Name="ClearRoiButton" Content="Clear" Appearance="Secondary" Grid.Column="1" Margin="0,0,5,0" Click="ClearRoi_Click" IsEnabled="False" Height="38" />
                        <ui:Button x:Name="CropButton" Content="Crop" Appearance="Primary" Grid.Column="2" Click="Crop_Click" IsEnabled="False" Height="38" />
                    </Grid>

                    <!-- Profile Sampling -->
                    <TextBlock Text="Profile Sampling" Style="{StaticResource DosimetrySectionHeader}" Margin="0,15,0,8" />
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ui:Button x:Name="PickProfileButton" Content="Pick Point" Icon="{ui:SymbolIcon TargetArrow24}" Appearance="Secondary" Click="PickProfilePoint_Click" HorizontalAlignment="Stretch" Margin="0,0,5,0" Height="38" />
                        <ComboBox x:Name="ProfileAxisCombo" Grid.Column="1" HorizontalAlignment="Stretch" Height="38" FontSize="11" SelectionChanged="ProfileAxisCombo_SelectionChanged">
                            <ComboBoxItem Content="X Profile" IsSelected="True" />
                            <ComboBoxItem Content="Y Profile" />
                        </ComboBox>
                    </Grid>

                    <!-- Alignment -->
                    <TextBlock Text="Spatial Alignment (mm)" Style="{StaticResource DosimetrySectionHeader}" Margin="0,20,0,10" />
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <TextBlock Text="X Shift" FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <ui:NumberBox x:Name="XShiftInput" Value="0" SmallChange="0.1" ValueChanged="Alignment_Changed" Height="38" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                            <TextBlock Text="Y Shift" FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <ui:NumberBox x:Name="YShiftInput" Value="0" SmallChange="0.1" ValueChanged="Alignment_Changed" Height="38" />
                        </StackPanel>
                    </Grid>

                    <!-- Gamma Parameters -->
                    <TextBlock Text="Gamma Criteria" Style="{StaticResource DosimetrySectionHeader}" Margin="0,10,0,10" />
                    <ui:Card Padding="12" Margin="0,0,0,20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="DD (%)" VerticalAlignment="Center" FontSize="11" Margin="0,0,10,10"/>
                            <ui:NumberBox x:Name="GammaDdInput" Grid.Row="0" Grid.Column="1" Value="2" Minimum="0.1" Margin="0,0,0,10" ValueChanged="GammaParams_Changed" Height="34"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="DTA (mm)" VerticalAlignment="Center" FontSize="11" Margin="0,0,10,10"/>
                            <ui:NumberBox x:Name="GammaDtaInput" Grid.Row="1" Grid.Column="1" Value="2" Minimum="0.1" Margin="0,0,0,10" ValueChanged="GammaParams_Changed" Height="34"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Threshold (%)" VerticalAlignment="Center" FontSize="11" Margin="0,0,10,10"/>
                            <ui:NumberBox x:Name="GammaThresholdInput" Grid.Row="2" Grid.Column="1" Value="10" Minimum="0" Maximum="100" Margin="0,0,0,10" ValueChanged="GammaParams_Changed" Height="34" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Fractions" VerticalAlignment="Center" FontSize="11" Margin="0,0,10,10"/>
                            <ui:NumberBox x:Name="FractionsInput" Grid.Row="3" Grid.Column="1" Value="1" Minimum="1" Margin="0,0,0,10" ValueChanged="Alignment_Changed" Height="34"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Mode" VerticalAlignment="Center" FontSize="11" Margin="0,0,10,0"/>
                            <ComboBox x:Name="GammaModeCombo" Grid.Row="4" Grid.Column="1" SelectedIndex="0" SelectionChanged="GammaParams_Changed" HorizontalAlignment="Stretch" Height="34">
                                <ComboBoxItem Content="Global Normalization" />
                                <ComboBoxItem Content="Local Normalization" />
                            </ComboBox>
                        </Grid>
                    </ui:Card>

                    <ui:Button x:Name="RunAnalysisButton" 
                               Content="Run Analysis" 
                               Icon="{ui:SymbolIcon Play24}" 
                               Appearance="Primary" 
                               HorizontalAlignment="Stretch" 
                               Height="48" 
                               Click="RunAnalysisButton_Click" 
                               IsEnabled="False"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Main Workspace (2x2 Grid) -->
        <Grid Grid.Column="1" Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Top Left: Measured Dose -->
            <Border Grid.Row="0" Grid.Column="0" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="4" Margin="5" Padding="2">
                <Grid>
                    <Canvas x:Name="MeasuredCanvas" ClipToBounds="True" Background="Transparent"
                            MouseLeftButtonDown="RoiCanvas_MouseDown" MouseMove="RoiCanvas_MouseMove" MouseLeftButtonUp="RoiCanvas_MouseUp">
                        <Image x:Name="MeasuredImage" Stretch="Uniform" 
                               Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Canvas}}" 
                               Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Canvas}}">
                            <Image.RenderTransform>
                                <TranslateTransform x:Name="MeasuredImageTranslation" />
                            </Image.RenderTransform>
                        </Image>
                        <Rectangle x:Name="MeasuredRoiRect" Stroke="Cyan" StrokeThickness="1.5" StrokeDashArray="4,2" Fill="#18FFFFFF" Visibility="Collapsed" />
                        <Line x:Name="MeasuredProfileLineH" Stroke="Orange" StrokeThickness="1.2" Visibility="Collapsed" />
                        <Line x:Name="MeasuredProfileLineV" Stroke="Orange" StrokeThickness="1.2" Visibility="Collapsed" />
                    </Canvas>
                    
                    <!-- File Name Overlay (Top Right) -->
                    <Border x:Name="FilmOverlayBorder" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10" Background="#99000000" CornerRadius="4" Padding="8,4" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Film: " Foreground="#CCCCCC" FontSize="10" FontWeight="Bold"/>
                            <TextBlock x:Name="FilmOverlayText" Text="None" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="MeasuredEmptyMsg" Text="No Film Dose Loaded" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </Grid>
            </Border>

            <!-- Top Right: Planned Dose -->
            <Border Grid.Row="0" Grid.Column="1" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="4" Margin="5" Padding="2">
                <Grid>
                    <Canvas x:Name="PlannedCanvas" ClipToBounds="True" Background="Transparent"
                            MouseLeftButtonDown="RoiCanvas_MouseDown" MouseMove="RoiCanvas_MouseMove" MouseLeftButtonUp="RoiCanvas_MouseUp">
                        <Image x:Name="PlannedImage" Stretch="Uniform"
                               Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Canvas}}"
                               Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Canvas}}" />
                        <Rectangle x:Name="PlannedRoiRect" Stroke="Cyan" StrokeThickness="1.5" StrokeDashArray="4,2" Fill="#18FFFFFF" Visibility="Collapsed" />
                        <Line x:Name="PlannedProfileLineH" Stroke="Orange" StrokeThickness="1.2" Visibility="Collapsed" />
                        <Line x:Name="PlannedProfileLineV" Stroke="Orange" StrokeThickness="1.2" Visibility="Collapsed" />
                    </Canvas>

                    <!-- File Name Overlay (Top Right) -->
                    <Border x:Name="DicomOverlayBorder" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10" Background="#99000000" CornerRadius="4" Padding="8,4" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="DICOM: " Foreground="#CCCCCC" FontSize="10" FontWeight="Bold"/>
                            <TextBlock x:Name="DicomOverlayText" Text="None" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="PlannedEmptyMsg" Text="No Plan Dose Loaded" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </Grid>
            </Border>

            <!-- Bottom Left: Profiles -->
            <Border Grid.Row="1" Grid.Column="0" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="4" Margin="5" Padding="5">
                <ScottPlot:WpfPlot x:Name="ProfilePlot" />
            </Border>

            <!-- Bottom Right: Gamma Map -->
            <Border Grid.Row="1" Grid.Column="1" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="4" Margin="5" Padding="2" Background="#15FFFFFF">
                <Grid>
                    <Image x:Name="GammaImage" Stretch="Uniform" />
                    
                    <!-- Gamma Results Overlay (Top Left Header) -->
                    <Border x:Name="GammaResultsOverlay" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5" Background="#40FFFFFF" CornerRadius="4" Padding="10,2" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="GAMMA PASS RATE: " Foreground="#AAAAAA" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="OverlayPassRateText" Text="--" Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,10,0"/>
                            <TextBlock x:Name="OverlayStatusText" Text="--" Foreground="#888888" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="GammaEmptyMsg" Text="Run Analysis to view Gamma Map" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#666666" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

<UserControl x:Class="FilmAnalysis.AnalysisControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:FilmAnalysis"
             xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200">
    <Grid Background="{DynamicResource ApplicationBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar Controls -->
        <Border Grid.Column="0" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="0,0,1,0" Padding="15">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Dose Comparison" FontSize="18" Style="{StaticResource DosimetrySectionHeader}" Margin="0,0,0,20" />

                    <!-- Sources -->
                    <TextBlock Text="Data Sources" Style="{StaticResource DosimetrySectionHeader}" Margin="0,0,0,10" />
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ui:Button x:Name="SyncFilmButton" Content="Sync Film" Icon="{ui:SymbolIcon ArrowSync24}" HorizontalAlignment="Stretch" Margin="0,0,5,0" Click="SyncFilmButton_Click" />
                        <ui:Button x:Name="SyncDicomButton" Grid.Column="1" Content="Sync DICOM" Icon="{ui:SymbolIcon CubeSync24}" HorizontalAlignment="Stretch" Click="SyncDicomButton_Click" />
                    </Grid>
                    
                    <!-- (Data Source Info moved to Gamma Map overlay) -->

                    <!-- ROI Selection -->
                    <TextBlock Text="Region of Interest" Style="{StaticResource DosimetrySectionHeader}" Margin="0,0,0,5" />
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:Button x:Name="SelectRoiButton" Content="Select ROI" Icon="{ui:SymbolIcon Crop24}" HorizontalAlignment="Stretch" Grid.Column="0" Margin="0,0,5,0" Click="SelectRoi_Click" IsEnabled="False" />
                        <ui:Button x:Name="ClearRoiButton" Content="Clear" Appearance="Secondary" Grid.Column="1" Margin="0,0,5,0" Click="ClearRoi_Click" IsEnabled="False" />
                        <ui:Button x:Name="CropButton" Content="Crop" Appearance="Primary" Grid.Column="2" Click="Crop_Click" IsEnabled="False" />
                    </Grid>
                    <TextBlock x:Name="RoiStatusText" Text="No ROI selected" FontSize="9" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,15" />

                    <!-- Alignment -->
                    <TextBlock Text="Spatial Alignment (mm)" Style="{StaticResource DosimetrySectionHeader}" Margin="0,0,0,10" />
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <TextBlock Text="X Shift" FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <ui:NumberBox x:Name="XShiftInput" Value="0" SmallChange="0.1" ValueChanged="Alignment_Changed" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                            <TextBlock Text="Y Shift" FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <ui:NumberBox x:Name="YShiftInput" Value="0" SmallChange="0.1" ValueChanged="Alignment_Changed" />
                        </StackPanel>
                    </Grid>

                    <!-- Gamma Parameters -->
                    <TextBlock Text="Gamma Criteria" Style="{StaticResource DosimetrySectionHeader}" Margin="0,0,0,10" />
                    <ui:Card Padding="10" Margin="0,0,0,20">
                        <Grid Margin="0,5,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="DTA (mm)" VerticalAlignment="Center" FontSize="11" Margin="0,0,10,10"/>
                            <ui:NumberBox x:Name="GammaDtaInput" Grid.Row="0" Grid.Column="1" Value="2" Minimum="0.1" Margin="0,0,0,10" ValueChanged="GammaParams_Changed"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="DD (%)" VerticalAlignment="Center" FontSize="11" Margin="0,0,10,10"/>
                            <ui:NumberBox x:Name="GammaDdInput" Grid.Row="1" Grid.Column="1" Value="2" Minimum="0.1" Margin="0,0,0,10" ValueChanged="GammaParams_Changed"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Threshold (%)" VerticalAlignment="Center" FontSize="11" Margin="0,0,10,10"/>
                            <ui:NumberBox x:Name="GammaThresholdInput" Grid.Row="2" Grid.Column="1" Value="10" Minimum="0" Maximum="100" Margin="0,0,0,10" ValueChanged="GammaParams_Changed" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Plan Fx" VerticalAlignment="Center" FontSize="11" Margin="0,0,10,10"/>
                            <ui:NumberBox x:Name="FractionsInput" Grid.Row="3" Grid.Column="1" Value="1" Minimum="1" Margin="0,0,0,10" ValueChanged="Alignment_Changed"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Mode" VerticalAlignment="Center" FontSize="11" Margin="0,0,10,0"/>
                            <ComboBox x:Name="GammaModeCombo" Grid.Row="4" Grid.Column="1" SelectedIndex="0" Margin="0,0,0,0" SelectionChanged="GammaParams_Changed">
                                <ComboBoxItem Content="Global %" />
                                <ComboBoxItem Content="Local %" />
                            </ComboBox>
                        </Grid>
                    </ui:Card>

                    <ui:Button x:Name="RunAnalysisButton" 
                               Content="Run Analysis" 
                               Icon="{ui:SymbolIcon Play24}" 
                               Appearance="Primary" 
                               HorizontalAlignment="Stretch" 
                               Height="45" 
                               Click="RunAnalysisButton_Click" 
                               IsEnabled="False"/>
                    


                    <Border x:Name="ResultsPanel" Margin="0,20,0,0" Visibility="Collapsed">
                         <StackPanel>
                             <TextBlock Text="Results" Style="{StaticResource DosimetrySectionHeader}" FontSize="16" Margin="0,0,0,10" />
                             <Border Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="2" Padding="15">
                                 <StackPanel>
                                     <TextBlock Text="Gamma Pass Rate" FontSize="12" HorizontalAlignment="Center"/>
                                     <TextBlock x:Name="PassRateText" Text="98.5 %" FontSize="28" FontWeight="Bold" Foreground="Lime" HorizontalAlignment="Center" Margin="0,5"/>
                                     <TextBlock x:Name="PassRateStatus" Text="PASS (Criteria: 90%)" FontSize="10" HorizontalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                 </StackPanel>
                             </Border>
                         </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Main Workspace (2x2 Grid) -->
        <Grid Grid.Column="1" Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Top Left: Measured Dose -->
            <Border Grid.Row="0" Grid.Column="0" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="4" Margin="5" Padding="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Measured (Film)" HorizontalAlignment="Center" FontWeight="SemiBold" Margin="5" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <Canvas x:Name="MeasuredCanvas" Grid.Row="1" ClipToBounds="True" Background="Transparent"
                            MouseLeftButtonDown="RoiCanvas_MouseDown" MouseMove="RoiCanvas_MouseMove" MouseLeftButtonUp="RoiCanvas_MouseUp">
                        <Image x:Name="MeasuredImage" Stretch="Uniform" 
                               Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Canvas}}" 
                               Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Canvas}}">
                            <Image.RenderTransform>
                                <TranslateTransform x:Name="MeasuredImageTranslation" />
                            </Image.RenderTransform>
                        </Image>
                        <Rectangle x:Name="MeasuredRoiRect" Stroke="Cyan" StrokeThickness="1.5" StrokeDashArray="4,2" Fill="#18FFFFFF" Visibility="Collapsed" />
                    </Canvas>
                    <TextBlock x:Name="MeasuredEmptyMsg" Grid.Row="1" Text="No Film Dose Loaded" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </Grid>
            </Border>

            <!-- Top Right: Planned Dose -->
            <Border Grid.Row="0" Grid.Column="1" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="4" Margin="5" Padding="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Planned (DICOM)" HorizontalAlignment="Center" FontWeight="SemiBold" Margin="5" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <Canvas x:Name="PlannedCanvas" Grid.Row="1" ClipToBounds="True" Background="Transparent"
                            MouseLeftButtonDown="RoiCanvas_MouseDown" MouseMove="RoiCanvas_MouseMove" MouseLeftButtonUp="RoiCanvas_MouseUp">
                        <Image x:Name="PlannedImage" Stretch="Uniform"
                               Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Canvas}}"
                               Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Canvas}}" />
                        <Rectangle x:Name="PlannedRoiRect" Stroke="Cyan" StrokeThickness="1.5" StrokeDashArray="4,2" Fill="#18FFFFFF" Visibility="Collapsed" />
                    </Canvas>
                    <TextBlock x:Name="PlannedEmptyMsg" Grid.Row="1" Text="No Plan Dose Loaded" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </Grid>
            </Border>

            <!-- Bottom Left: Profiles -->
            <Border Grid.Row="1" Grid.Column="0" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="4" Margin="5" Padding="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Profile Comparison" FontWeight="SemiBold" Margin="5" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <ComboBox x:Name="ProfileAxisCombo" Width="101" Height="35" Margin="10,0,0,0" FontSize="10" SelectionChanged="ProfileAxisCombo_SelectionChanged">
                            <ComboBoxItem Content="X-Axis" IsSelected="True" />
                            <ComboBoxItem Content="Y-Axis" />
                        </ComboBox>
                    </StackPanel>
                    <ScottPlot:WpfPlot x:Name="ProfilePlot" Grid.Row="1" />
                </Grid>
            </Border>

            <!-- Bottom Right: Gamma Map -->
            <Border Grid.Row="1" Grid.Column="1" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="4" Margin="5" Padding="5" Background="#111111">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Gamma Index Map" HorizontalAlignment="Center" FontWeight="SemiBold" Margin="5" Foreground="White" Opacity="0.7"/>
                    <Image x:Name="GammaImage" Grid.Row="1" Stretch="Uniform" />
                    
                    <!-- Dose Source Overlay (Top Right) -->
                    <StackPanel Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10">
                        <Border Background="#99000000" CornerRadius="4" Padding="8,4" Margin="0,0,0,5" x:Name="FilmOverlayBorder" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Film: " Foreground="#CCCCCC" FontSize="10" FontWeight="Bold"/>
                                <TextBlock x:Name="FilmOverlayText" Text="None" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#99000000" CornerRadius="4" Padding="8,4" x:Name="DicomOverlayBorder" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="DICOM: " Foreground="#CCCCCC" FontSize="10" FontWeight="Bold"/>
                                <TextBlock x:Name="DicomOverlayText" Text="None" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <TextBlock x:Name="GammaEmptyMsg" Grid.Row="1" Text="Run Analysis to view Gamma Map" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#666666" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

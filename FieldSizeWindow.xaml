<ui:FluentWindow x:Class="FilmQA.FieldSizeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:scott="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        Title="Field size Analysis (FWHM) &amp; Alignment" Height="950" Width="1200"
        Icon="/Icon.png"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
        WindowBackdropType="None"
        MouseDown="Window_MouseDown">
    
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar: Parameters & Results -->
        <Border Grid.Column="0" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Padding="0,0,15,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    
                    <TextBlock Text="Alignment Parameters" Style="{StaticResource DosimetrySectionHeader}" Margin="0,0,0,15" />
                    <ui:Card Padding="12" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Nominal Field Size" FontWeight="Bold" Margin="0,0,0,10" />
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Width (mm)" FontSize="10" Margin="0,0,0,4"/>
                                    <ui:TextBox x:Name="TargetSizeXBox" Text="50" HorizontalAlignment="Stretch" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Height (mm)" FontSize="10" Margin="0,0,0,4"/>
                                    <ui:TextBox x:Name="TargetSizeYBox" Text="50" HorizontalAlignment="Stretch" />
                                </StackPanel>
                            </Grid>
                            
                            <ui:Button Content="Apply Reticle Size" Icon="{ui:SymbolIcon Square24}" Appearance="Secondary" HorizontalAlignment="Stretch" Height="36" Click="ApplyReticleSize_Click" Margin="0,0,0,10" />
                            
                            <Grid HorizontalAlignment="Center" Margin="0,5,0,5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <ui:Button Grid.Row="0" Grid.Column="0" Content="CCW" Icon="{ui:SymbolIcon ArrowCounterclockwise24}" Width="60" Height="32" Click="DPadRotateCCW_Click" ToolTip="Rotate -0.5 deg" Margin="2"/>
                                <ui:Button Grid.Row="0" Grid.Column="1" Icon="{ui:SymbolIcon ArrowUp24}" Width="60" Height="32" Click="DPadUp_Click" Margin="2"/>
                                <ui:Button Grid.Row="0" Grid.Column="2" Content="CW" Icon="{ui:SymbolIcon ArrowClockwise24}" Width="60" Height="32" Click="DPadRotateCW_Click" ToolTip="Rotate +0.5 deg" Margin="2"/>
                                
                                <ui:Button Grid.Row="1" Grid.Column="0" Icon="{ui:SymbolIcon ArrowLeft24}" Width="60" Height="32" Click="DPadLeft_Click" Margin="2"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="Nudge" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                <ui:Button Grid.Row="1" Grid.Column="2" Icon="{ui:SymbolIcon ArrowRight24}" Width="60" Height="32" Click="DPadRight_Click" Margin="2"/>
                                
                                <ui:Button Grid.Row="2" Grid.Column="1" Icon="{ui:SymbolIcon ArrowDown24}" Width="60" Height="32" Click="DPadDown_Click" Margin="2"/>
                            </Grid>

                            <TextBlock Text="You may also drag the box on the right. Hit Recalculate Analysis when perfectly aligned!" FontStyle="Italic" FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,10,0,0"/>
                        </StackPanel>
                    </ui:Card>

                    <TextBlock Text="Field size Parameters" Style="{StaticResource DosimetrySectionHeader}" Margin="0,0,0,15" />
                    <ui:Card Padding="12" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Analysis Area" FontWeight="Bold" Margin="0,0,0,10" />
                            
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Plateau X (mm)" FontSize="10" Margin="0,0,0,4"/>
                                    <ui:TextBox x:Name="PlateauXBox" Text="20" HorizontalAlignment="Stretch" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Plateau Y (mm)" FontSize="10" Margin="0,0,0,4"/>
                                    <ui:TextBox x:Name="PlateauYBox" Text="20" HorizontalAlignment="Stretch" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Analysis Method" FontSize="11" Margin="0,0,0,5" />
                            <ComboBox x:Name="MethodBox" HorizontalAlignment="Stretch" Height="38" Margin="0,0,0,20">
                                <ComboBoxItem Content="Maximum" IsSelected="True" />
                                <ComboBoxItem Content="Mean" />
                                <ComboBoxItem Content="Median" />
                            </ComboBox>

                            <ui:Button Content="Recalculate Analysis" Icon="{ui:SymbolIcon Calculator24}" Appearance="Primary" HorizontalAlignment="Stretch" Height="42" Click="CalcButton_Click" />
                        </StackPanel>
                    </ui:Card>

                    <TextBlock Text="Results" Style="{StaticResource DosimetrySectionHeader}" Margin="0,10,0,10" />
                    <ui:Card Padding="15">
                        <StackPanel>
                            <TextBlock x:Name="ResultText" Text="FWHM X = --- mm&#x0a;FWHM Y = --- mm&#x0a;Coverage = --- mm²" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,15" Foreground="{DynamicResource AccentFillColorDefaultBrush}"/>
                            
                            <Border Background="{DynamicResource ControlFillColorSecondaryBrush}" CornerRadius="4" Padding="8,6">
                                <TextBlock x:Name="StatusText" Text="Ready for Analysis" FontSize="11" FontStyle="Italic" HorizontalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </Border>
                        </StackPanel>
                    </ui:Card>

                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ui:Button Grid.Column="0" Content="Print Report" Icon="{ui:SymbolIcon Print24}" 
                                   Appearance="Info" Opacity="0.75" HorizontalAlignment="Stretch" 
                                   Margin="0,0,5,0" Click="PrintReport_Click" />
                        <ui:Button Grid.Column="1" Content="Close Analysis" Icon="{ui:SymbolIcon Dismiss24}" 
                                   Appearance="Danger" Opacity="0.75" HorizontalAlignment="Stretch" 
                                   Margin="5,0,0,0" Click="Close_Click" />
                    </Grid>

                    <TextBlock Text="Analysis based on 50% FWHM from normalized plateau." FontStyle="Italic" FontSize="10.5" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,20,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Main Content Area: Plots -->
        <Grid Grid.Column="1" Margin="15,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="1.1*" />
                <RowDefinition Height="0.9*" />
            </Grid.RowDefinitions>

            <!-- 2D Image View with Draggable overlay -->
            <Border Grid.Row="0" Margin="0,0,0,8" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="5" Background="{DynamicResource ControlFillColorDefaultBrush}">
                <Grid x:Name="ImageBoxGrid" ClipToBounds="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <Viewbox Stretch="Uniform">
                         <Grid x:Name="AlignGrid">
                            <Image x:Name="FilmImage" Stretch="Fill" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                            <Canvas x:Name="OverlayCanvas" Background="Transparent" HorizontalAlignment="Left" VerticalAlignment="Top"
                                    Width="{Binding Width, ElementName=FilmImage}" 
                                    Height="{Binding Height, ElementName=FilmImage}"
                                    MouseDown="OverlayCanvas_MouseDown" 
                                    MouseMove="OverlayCanvas_MouseMove" 
                                    MouseUp="OverlayCanvas_MouseUp" 
                                    Focusable="True"
                                    KeyDown="OverlayCanvas_KeyDown">
                                <!-- Draggable target box -->
                                <Rectangle x:Name="TargetRect" RenderTransformOrigin="0.5,0.5" Stroke="White" StrokeThickness="1" Fill="#44FF0000" Visibility="Hidden" IsHitTestVisible="False">
                                    <Rectangle.RenderTransform>
                                        <RotateTransform x:Name="TargetRotation" Angle="0"/>
                                    </Rectangle.RenderTransform>
                                </Rectangle>
                                
                                <!-- Center crosshair point -->
                                <Ellipse x:Name="TargetCenter" Width="6" Height="6" Fill="Red" Visibility="Hidden" IsHitTestVisible="False" Margin="-3,-3,0,0"/>
                            </Canvas>
                         </Grid>
                    </Viewbox>
                    
                    <TextBlock Text="ALIGNMENT / DOSE MAP" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,8,12,0" 
                               FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                </Grid>
            </Border>

            <!-- Plots Grid -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- X-Profile Plot -->
                <Border Grid.Column="0" Margin="0,0,4,0" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="5" Background="{DynamicResource ControlFillColorDefaultBrush}">
                    <Grid>
                        <scott:WpfPlot x:Name="XPlot" />
                        <TextBlock Text="X-AXIS DOSIMETRY PROFILE" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,8,12,0" 
                                   FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                    </Grid>
                </Border>

                <!-- Y-Profile Plot -->
                <Border Grid.Column="1" Margin="4,0,0,0" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="5" Background="{DynamicResource ControlFillColorDefaultBrush}">
                    <Grid>
                        <scott:WpfPlot x:Name="YPlot" />
                        <TextBlock Text="Y-AXIS DOSIMETRY PROFILE" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,8,12,0" 
                                   FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>

<ui:FluentWindow x:Class="FilmAnalysis.JawSizeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:scott="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        Title="Jaw Size (FWHM)" Height="800" Width="1000"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
        WindowBackdropType="None">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Margin="0,0,0,10" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="DeveloperBoard24" Margin="0,0,10,0" FontSize="20"/>
                    <TextBlock Text="JAW SIZE ANALYSIS" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <ui:Button Content="Close" HorizontalAlignment="Right" Click="Close_Click" Appearance="Secondary"/>
            </Grid>
        </Border>

        <!-- Parameters and Summary -->
        <ui:Card Grid.Row="1" Margin="0,0,0,15" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="1" /> <!-- Divider line -->
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                
                <!-- Input Controls -->
                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                    <TextBlock Text="PARAMETERS" FontSize="11" FontWeight="Bold" Margin="0,0,0,10" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,5,10">
                            <TextBlock Text="Plateau X (mm)" FontSize="10" Margin="0,0,0,4"/>
                            <ui:TextBox x:Name="PlateauXBox" Text="20" HorizontalAlignment="Stretch" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="5,0,0,10">
                            <TextBlock Text="Plateau Y (mm)" FontSize="10" Margin="0,0,0,4"/>
                            <ui:TextBox x:Name="PlateauYBox" Text="20" HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </Grid>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Method" FontSize="10" Margin="0,0,0,4"/>
                        <ComboBox x:Name="MethodBox" HorizontalAlignment="Stretch" Height="38">
                            <ComboBoxItem Content="Maximum" IsSelected="True" />
                            <ComboBoxItem Content="Mean" />
                            <ComboBoxItem Content="Median" />
                        </ComboBox>
                    </StackPanel>
                    <ui:Button Content="Recalculate Analysis" Icon="{ui:SymbolIcon Calculator24}" HorizontalAlignment="Stretch" Click="CalcButton_Click" Appearance="Primary" />
                </StackPanel>

                <!-- Divider -->
                <Rectangle Grid.Column="1" Fill="{DynamicResource ControlStrokeColorDefaultBrush}" VerticalAlignment="Stretch" Margin="0,5"/>

                <!-- Results Display -->
                <StackPanel Grid.Column="2" Margin="15,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="RESULTS" FontSize="11" FontWeight="Bold" Margin="0,0,0,10" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="ResultText" Text="FWHM X = --- mm&#x0a;FWHM Y = --- mm&#x0a;Coverage = --- mm²&#x0a;Method = ---" FontWeight="SemiBold" FontSize="11.5" TextWrapping="Wrap" Margin="0,0,0,10"/>
                    <Border Background="{DynamicResource ControlFillColorSecondaryBrush}" CornerRadius="4" Padding="8,4">
                        <TextBlock x:Name="StatusText" Text="Ready" FontSize="10" FontStyle="Italic" HorizontalAlignment="Center" />
                    </Border>
                </StackPanel>
            </Grid>
        </ui:Card>

        <!-- Profile Plots -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- X-Profile Plot -->
            <Grid Grid.Column="0" Margin="0,0,5,0">
                <Border BorderThickness="1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" CornerRadius="4">
                    <scott:WpfPlot x:Name="XPlot" MinHeight="180"/>
                </Border>
                <TextBlock Text="X-Axis Profile" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,5,0,0" 
                           FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
            </Grid>

            <!-- Y-Profile Plot -->
            <Grid Grid.Column="1" Margin="5,0,0,0">
                <Border BorderThickness="1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" CornerRadius="4">
                    <scott:WpfPlot x:Name="YPlot" MinHeight="180"/>
                </Border>
                <TextBlock Text="Y-Axis Profile" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,5,0,0" 
                           FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
            </Grid>
        </Grid>

        <!-- Footer -->
        <TextBlock Grid.Row="3" Text="Analysis based on 50% FWHM from normalized plateau."                    FontStyle="Italic" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
    </Grid>
</ui:FluentWindow>

<ui:FluentWindow x:Class="FilmAnalysis.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:FilmAnalysis"
        mc:Ignorable="d"
        Title="Film Analysis" Height="900" Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica" 
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38" />
            <!-- Stable Header (Fixes clipping) -->
            <RowDefinition />
            <!-- Main Content (Expanded) -->
            <RowDefinition Height="Auto" />
            <!-- Stable Footer -->
        </Grid.RowDefinitions>

        <!-- Root host for dialogs -->
        <ContentPresenter x:Name="RootContentDialogPresenter" Grid.RowSpan="3" Panel.ZIndex="1001" />

        <!-- Compact Top Header Area (Title + Menu + Window Controls) -->
        <Grid Grid.Row="0" Background="Transparent">
            <!-- 1. Background TitleBar: Handles window dragging and menus -->
            <ui:TitleBar Title="" Height="38" Background="Transparent" Padding="0,4,0,4">
                <ui:TitleBar.Header>
                    <Menu Background="Transparent" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="11">
                        <Menu.ItemContainerStyle>
                            <Style TargetType="MenuItem">
                                <Setter Property="Padding" Value="10,0"/>
                                <Setter Property="MinHeight" Value="28"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="#FF000000"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </Menu.ItemContainerStyle>
                        <MenuItem Header="_File" Padding="5,0,5,0" Height="45">
                            <MenuItem Header="_Open..." Click="Open_Click" />
                            <MenuItem Header="Load raw film (tif/tif)" Click="LoadRawFilm_Click" />
                            <Separator />
                            <MenuItem Header="_Import">
                                <MenuItem Header="Dose Map (*.txt)" Click="ImportDoseMap_Click" />
                            </MenuItem>
                            <MenuItem Header="_Export">
                                <MenuItem Header="Dose Map (*.txt)" Click="ExportDoseMap_Click" />
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="_Settings..." Click="Settings_Click" />
                            <Separator />
                            <MenuItem Header="E_xit" Click="Exit_Click" />
                        </MenuItem>
                        <MenuItem Header="_Edit" Padding="5,0,5,0" Height="45">
                            <MenuItem x:Name="UndoMenuItem" Header="_Undo" Click="Undo_Click" InputGestureText="Ctrl+Z" IsEnabled="False" />
                            <MenuItem x:Name="RedoMenuItem" Header="_Redo" Click="Redo_Click" InputGestureText="Ctrl+Y" IsEnabled="False" />
                        </MenuItem>
                        <MenuItem Header="_View" Height="45">
                            <MenuItem Header="Calibration" Click="MenuSelectCalibration_Click" />
                            <MenuItem Header="Dicom View" Click="MenuSelectDicom_Click" />
                        </MenuItem>
                        <MenuItem Header="_Tools" Height="45">
                            <MenuItem Header="Jaw Size (FWHM)" Click="JawSizeMenu_Click" />
                        </MenuItem>
                    </Menu>
                </ui:TitleBar.Header>
            </ui:TitleBar>

            <!-- 2. Foreground Title Overlay: Dynamic Contrast -->
            <Grid IsHitTestVisible="False">
                <ui:TextBlock 
                    Text="Film Dosimetry Analysis" 
                    FontTypography="Caption" 
                    FontWeight="Bold" 
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            </Grid>
        </Grid>

        <!-- Main content (Now headerless) -->
        <TabControl x:Name="MainTabControl" Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="10">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Style>
            </TabControl.ItemContainerStyle>
            <!-- Calibration Tab -->
            <TabItem Header="Calibration">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="350" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="350" />
                    </Grid.ColumnDefinitions>

                    <!-- Left Stack: Transform, Filters, Dose + Metadata -->
                    <Grid Grid.Column="0" Margin="0,0,10,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TabControl Grid.Row="0" TabStripPlacement="Bottom">
                            <!-- Tab 1: Transform & Align -->
                            <TabItem Header="Transform">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="10">
                                        <TextBlock Text="Alignment Tools" FontWeight="Bold" Margin="0,0,0,10" />
                                        <ui:Button x:Name="AutoAlignCenterButton" Content="Auto Center" Icon="{ui:SymbolIcon TargetArrow24}" Width="310" Margin="0,0,0,8" Click="AutoCenter_Click" />
                                        <ui:Button x:Name="ManuallyAlignButton" Content="Manually Align (3-Point)" Icon="{ui:SymbolIcon Cursor24}" Width="310" Margin="0,0,0,8" Click="ManuallyAlign_Click" />
                                        <ui:Button x:Name="AutoAlignImageButton" Content="Auto Align Image" Icon="{ui:SymbolIcon DrawImage24}" Width="310" Margin="0,0,0,15" Click="AutoAlign_Click" />

                                        <TextBlock Text="Orientation" FontWeight="Bold" Margin="0,0,0,10" />
                                        <Grid Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <ui:Button x:Name="CWButton" Icon="{ui:SymbolIcon ArrowRotateClockwise24}" Grid.Column="0" Width="70" Click="Rotation_Click" ToolTip="Rotate CW 90°" />
                                            <ui:Button x:Name="CCWButton" Icon="{ui:SymbolIcon ArrowRotateCounterclockwise24}" Grid.Column="1" Width="70" Click="Rotation_Click" ToolTip="Rotate CCW 90°" />
                                            <ui:Button x:Name="FlipHButton" Icon="{ui:SymbolIcon FlipHorizontal24}" Grid.Column="2" Width="70" Click="Flip_Click" ToolTip="Flip Horizontal" />
                                            <ui:Button x:Name="FlipVButton" Icon="{ui:SymbolIcon FlipVertical24}" Grid.Column="3" ToolTip="Flip Vertical" Width="70" Click="Flip_Click" />
                                        </Grid>

                                        <TextBlock Text="Cropping" FontWeight="Bold" Margin="0,0,0,10" />
                                        <ui:Button x:Name="ManualCropButton" Content="Manual Crop (Draw ROI)" Icon="{ui:SymbolIcon Crop24}" Width="310" Margin="0,0,0,8" Click="Crop_Click" />
                                        <Grid Margin="0,0,0,4" Width="310">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="W:" VerticalAlignment="Center" Margin="0,0,4,0" Grid.Column="0" />
                                            <TextBox x:Name="CenterCropWidth" Text="500" Grid.Column="1" Margin="0,0,8,0" />
                                            <TextBlock Text="H:" VerticalAlignment="Center" Margin="0,0,4,0" Grid.Column="2" />
                                            <TextBox x:Name="CenterCropHeight" Text="500" Grid.Column="3" />
                                        </Grid>
                                        <ui:Button x:Name="CenterCropButton" Content="Center Crop" Icon="{ui:SymbolIcon CenterHorizontal24}" Width="310" Margin="0,0,0,8" Click="Crop_Click" />
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <!-- Tab 2: Filters -->
                            <TabItem Header="Filters">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="10">
                                        <TextBlock Text="Image Enhancement" FontWeight="Bold" Margin="0,0,0,10" />
                                        <Grid Margin="0,0,0,8" Width="310">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="60" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Kernel:" VerticalAlignment="Center" Margin="0,0,6,0" Grid.Column="0" />
                                            <TextBox x:Name="MedianKernelSize" Text="3" Grid.Column="1" Margin="0,0,8,0" />
                                            <ui:Button x:Name="MedianFilterButton" Content="Median Filter" Icon="{ui:SymbolIcon FilterSync24}" Grid.Column="2" HorizontalAlignment="Stretch" Click="Filter_Click" />
                                        </Grid>
                                        <Grid Margin="0,0,0,8" Width="310">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="60" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Threshold:" VerticalAlignment="Center" Margin="0,0,6,0" Grid.Column="0" />
                                            <TextBox x:Name="NoiseThreshold" Text="65535" Grid.Column="1" Margin="0,0,8,0" />
                                            <ui:Button x:Name="NoiseFilterButton" Content="Noise Filter" Icon="{ui:SymbolIcon ShieldCheckmark24}" Grid.Column="2" HorizontalAlignment="Stretch" Click="Filter_Click" />
                                        </Grid>
                                        <ui:Button x:Name="ROIFilterButton" Content="ROI Filter (Zero Outside)" Icon="{ui:SymbolIcon FilterSync24}" Width="310" Margin="0,0,0,15" Click="Filter_Click" />

                                        <TextBlock Text="Smoothing" FontWeight="Bold" Margin="0,0,0,10" />
                                        <ComboBox x:Name="SmoothDropDown" Width="310" Margin="0,0,0,8">
                                            <ComboBoxItem Content="Average" IsSelected="True" />
                                            <ComboBoxItem Content="Median" />
                                            <ComboBoxItem Content="Gaussian" />
                                        </ComboBox>
                                        <Grid Margin="0,0,0,15" Width="310">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="60" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Window/σ:" VerticalAlignment="Center" Margin="0,0,6,0" Grid.Column="0" />
                                            <TextBox x:Name="SmoothStrength" Text="3" Grid.Column="1" Margin="0,0,8,0" />
                                            <ui:Button x:Name="SmoothButton" Content="Apply Smooth" Icon="{ui:SymbolIcon Cube24}" Grid.Column="2" HorizontalAlignment="Stretch" Click="Filter_Click" />
                                        </Grid>

                                        <TextBlock Text="Interpolation" FontWeight="Bold" Margin="0,0,0,10" />
                                        <ComboBox x:Name="InterpolationDropDown" Width="310" Margin="0,0,0,8">
                                            <ComboBoxItem Content="Nearest" />
                                            <ComboBoxItem Content="Linear" IsSelected="True" />
                                            <ComboBoxItem Content="Cubic" />
                                        </ComboBox>
                                        <Grid Margin="0,0,0,8" Width="310">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="60" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Scale:" VerticalAlignment="Center" Margin="0,0,6,0" Grid.Column="0" />
                                            <TextBox x:Name="InterpScale" Text="2" Grid.Column="1" Margin="0,0,8,0" />
                                            <ui:Button x:Name="InterpButton" Content="Apply Interpolation" Icon="{ui:SymbolIcon DrawImage24}" Grid.Column="2" HorizontalAlignment="Stretch" Click="Filter_Click" />
                                        </Grid>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <!-- Tab 3: Dose & Tools -->
                            <TabItem Header="Dose &amp; Tools">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="10">
                                        <TextBlock Text="Dose Conversion" FontWeight="Bold" Margin="0,0,0,10" />
                                        <ui:Button x:Name="ExtractROIButton" Content="Extract ROI" Icon="{ui:SymbolIcon DrawShape24}" Width="310" Margin="0,0,0,8" Click="ExtractROI_Click" ToolTip="Select region and extract RGB intensities" />
                                        <ui:Button x:Name="ConvertToDoseButton" Content="Convert to Dose" Icon="{ui:SymbolIcon Calculator24}" Background="{DynamicResource AccentFillColorDefaultBrush}" Foreground="White" Width="310" Margin="0,0,0,8" Click="ConvertToDose_Click" />
                                        <ui:ToggleSwitch x:Name="ShowDoseToggle" Content="Show Dose Map" Margin="0,0,0,8" Click="ShowDoseToggle_Click" IsEnabled="False" />
                                        <Border Background="{DynamicResource ControlFillColorSecondaryBrush}" Padding="10,5" CornerRadius="4" Margin="0,0,0,15">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Dose Range: " VerticalAlignment="Center"/>
                                                <TextBlock x:Name="DoseRangeText" Text="N/A" FontWeight="Bold" Foreground="{DynamicResource AccentFillColorDefaultBrush}"/>
                                            </StackPanel>
                                        </Border>

                                        <TextBlock Text="Visual Tools" FontWeight="Bold" Margin="0,0,0,10" />
                                        <TextBlock Text="Contrast Adjustment" Margin="0,0,0,5" />
                                        <Slider x:Name="ContrastSlider" Width="310" Margin="0,0,0,15" Minimum="0" Maximum="255" Value="128" ValueChanged="ContrastSlider_ValueChanged" />

                                        <TextBlock Text="Measurement Tools" FontWeight="Bold" Margin="0,0,0,10" />
                                        <UniformGrid Columns="2" Width="310" Margin="0,0,0,15">
                                            <ui:Button x:Name="ROIDoseButton" Content="ROI Dose" Icon="{ui:SymbolIcon DrawShape24}" HorizontalAlignment="Stretch" Margin="2" Click="Measurement_Click" />
                                            <ui:Button x:Name="ProfileButton" Content="Profiles" Icon="{ui:SymbolIcon Line24}" HorizontalAlignment="Stretch" Margin="2" Click="ProfileButton_Click" />
                                            <ui:Button x:Name="DistanceButton" Content="Distance" Icon="{ui:SymbolIcon Line24}" HorizontalAlignment="Stretch" Margin="2" Click="Measurement_Click" />
                                            <ui:Button x:Name="AreaButton" Content="Area" Icon="{ui:SymbolIcon DocumentTable24}" HorizontalAlignment="Stretch" Margin="2" Click="Measurement_Click" />
                                        </UniformGrid>

                                        <TextBlock Text="Color Map" FontWeight="Bold" Margin="0,0,0,5" />
                                        <TextBlock Text="Active Color Map" Margin="0,0,0,5" />
                                        <ComboBox x:Name="ColorMapDropDown" Width="310" Margin="0,0,0,8" SelectionChanged="ColorMapDropDown_SelectionChanged" />
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                        </TabControl>

                        <!-- Image Metadata Panel -->
                        <Border Grid.Row="1" Margin="0,10,0,0" Padding="15" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="Image Information" FontWeight="Bold" Margin="0,0,0,10" Foreground="{DynamicResource AccentFillColorDefaultBrush}" />
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="File:" Margin="0,0,10,4" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    <TextBlock x:Name="MetaFileName" Grid.Row="0" Grid.Column="1" Text="None" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Size:" Margin="0,0,10,4" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    <TextBlock x:Name="MetaImageSize" Grid.Row="1" Grid.Column="1" Text="0 x 0" FontWeight="SemiBold" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="DPI:" Margin="0,0,10,4" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    <TextBlock x:Name="MetaDPI" Grid.Row="2" Grid.Column="1" Text="72.0" FontWeight="SemiBold" />

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="File Size:" Margin="0,0,10,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    <TextBlock x:Name="MetaFileSize" Grid.Row="3" Grid.Column="1" Text="0.00 MB" FontWeight="SemiBold" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Main Display (Centered) -->
                    <Border x:Name="MainDisplay" Grid.Column="1" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" Background="{DynamicResource ControlFillColorDefaultBrush}" Padding="10" CornerRadius="8" Margin="10,0,10,0">
                        <Grid x:Name="MasterImageContainer">                            <Grid.RowDefinitions>
                                <RowDefinition Height="30" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="30" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>
                            
                            <!-- Ruler Bar Backgrounds (Framing the image) -->
                            <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Background="#F3F3F3" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="0,0,0,1" Panel.ZIndex="5" Opacity="0.7" />
                            <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Background="#F3F3F3" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="0,1,0,0" Panel.ZIndex="5" Opacity="0.7" />
                            <Border Grid.Row="1" Grid.Column="0" Background="#F3F3F3" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="0,0,1,0" Panel.ZIndex="5" Opacity="0.7" />
                            <Border Grid.Row="1" Grid.Column="2" Background="#F3F3F3" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1,0,0,0" Panel.ZIndex="5" Opacity="0.7" />

                            <TextBlock Text="mm" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Panel.ZIndex="11" />
                            
                            <Canvas x:Name="TopRulerCanvas" Grid.Row="0" Grid.Column="1" Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Panel.ZIndex="10" ClipToBounds="True" />
                            <Canvas x:Name="BottomRulerCanvas" Grid.Row="2" Grid.Column="1" Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Panel.ZIndex="10" ClipToBounds="True" />
                            <Canvas x:Name="LeftRulerCanvas" Grid.Row="1" Grid.Column="0" Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Panel.ZIndex="10" ClipToBounds="True" />
                            <Canvas x:Name="RightRulerCanvas" Grid.Row="1" Grid.Column="2" Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Panel.ZIndex="10" ClipToBounds="True" />

                            <Grid x:Name="ImageGrid" Grid.Row="1" Grid.Column="1" Background="Transparent">
                            <Image x:Name="MainDisplayImage" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center" 
                                   MouseDown="Image_MouseDown" MouseMove="Image_MouseMove" MouseUp="Image_MouseUp" />
                            <Canvas x:Name="SelectionCanvas" 
                                    IsHitTestVisible="True" 
                                    Background="Transparent"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    MouseDown="Image_MouseDown" 
                                    MouseMove="Image_MouseMove" 
                                    MouseUp="Image_MouseUp">
                                <Grid x:Name="ZeroAnchor" IsHitTestVisible="False" Opacity="0.15" Panel.ZIndex="1">
                                    <Line X1="0" X2="20" Y1="0" Y2="0" Stroke="Black" StrokeThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    <Line X1="0" X2="0" Y1="0" Y2="20" Stroke="Black" StrokeThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Grid>

                                <Rectangle x:Name="SelectionRect"
                                           Stroke="Transparent"
                                           StrokeThickness="0"
                                           Fill="#44FF0000" 
                                           Visibility="Collapsed" />
                                <!-- Crosshairs for Fixed ROI -->
                                 <Line x:Name="SelectionCrosshairH" Stroke="White" StrokeThickness="1" StrokeDashArray="4,4" Visibility="Collapsed" />
                                <Line x:Name="SelectionCrosshairV" Stroke="White" StrokeThickness="1" StrokeDashArray="4,4" Visibility="Collapsed" />

                                <!-- Manual Alignment Markers -->
                                <Ellipse x:Name="AlignMarkerLeft" Width="10" Height="10" Fill="Red" Stroke="White" StrokeThickness="1" Visibility="Collapsed" />
                                <Ellipse x:Name="AlignMarkerRight" Width="10" Height="10" Fill="DodgerBlue" Stroke="White" StrokeThickness="1" Visibility="Collapsed" />
                                <Ellipse x:Name="AlignMarkerTop" Width="10" Height="10" Fill="LimeGreen" Stroke="White" StrokeThickness="1" Visibility="Collapsed" />
                                <Ellipse x:Name="AlignMarkerIso" Width="14" Height="14" Fill="Yellow" Stroke="Black" StrokeThickness="1.5" Visibility="Collapsed" />

                                <!-- Measurement Tools Visualization -->
                                <Line x:Name="MeasurementLine" Stroke="Lime" StrokeThickness="2" Visibility="Collapsed" />
                                <Polyline x:Name="MeasurementPolyline" Stroke="Yellow" StrokeThickness="2" Visibility="Collapsed" />
                                <Border x:Name="MeasurementLabel" 
                                        Background="#CC000000" 
                                        BorderBrush="White" 
                                        BorderThickness="1" 
                                        CornerRadius="4" 
                                        Padding="5,2" 
                                        Visibility="Collapsed" 
                                        Panel.ZIndex="100">
                                    <TextBlock x:Name="MeasurementLabelText" Foreground="White" FontWeight="Bold" FontSize="11" Text="0.00" />
                                </Border>
                            </Canvas>

                            <!-- ROI Control Overlay -->
                            <StackPanel x:Name="ROIModeOverlay" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="15" Visibility="Collapsed">
                                <Border Background="#CC2D2D2D" CornerRadius="20" Padding="15,8" BorderBrush="#66FFFFFF" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="ROI TOOL ACTIVE" VerticalAlignment="Center" Foreground="White" FontWeight="Bold" Margin="0,0,15,0" FontSize="11" />
                                        <ui:Button Content="Exit ROI Mode" Icon="{ui:SymbolIcon Dismiss24}" Appearance="Danger" Click="ExitROIMode_Click" Height="30" Padding="15,0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Alignment Control Overlay -->
                            <StackPanel x:Name="AlignModeOverlay" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="15" Visibility="Collapsed">
                                <Border Background="#CC2D2D2D" CornerRadius="20" Padding="15,8" BorderBrush="#66FFFFFF" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="AlignStepText" Text="Click LEFT marker" VerticalAlignment="Center" Foreground="White" FontWeight="Bold" Margin="0,0,15,0" FontSize="11" />
                                        <ui:Button Content="Cancel" Icon="{ui:SymbolIcon Dismiss24}" Appearance="Danger" Click="ExitAlignMode_Click" Height="30" Padding="15,0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Right Stack: DataGrid and Profiles -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" /> <!-- Row 0: TabControl Area -->
                            <RowDefinition Height="*" />    <!-- Row 1: DataGrid Area -->
                            <RowDefinition Height="*" />    <!-- Row 2: Analysis Plot Area -->
                            <RowDefinition Height="Auto" /> <!-- Row 3: Status/Feedback Area -->
                        </Grid.RowDefinitions>

                        <!-- Processing Tabs Area -->
                        <TabControl Grid.Row="0" Margin="0,0,0,10" TabStripPlacement="Top">
                            <!-- Tab 1: Current Configuration (Loading/Status) -->
                            <TabItem Header="Current Config">
                                <Grid Margin="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Config Selection -->
                                    <Grid Grid.Row="0" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Config:" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <ComboBox x:Name="ConfigComboBox" Grid.Column="1" Height="38" HorizontalAlignment="Stretch" Margin="0,0,8,0" SelectionChanged="ConfigComboBox_SelectionChanged" />
                                        <ui:Button x:Name="RefreshConfigButton" Grid.Column="2" Icon="{ui:SymbolIcon ArrowSync24}" Width="42" Height="38" Click="RefreshConfigButton_Click" ToolTip="Reload Configurations" />
                                    </Grid>

                                    <!-- Info Display -->
                                    <Border Grid.Row="1" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="4" Padding="8">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <TextBlock x:Name="CalibrationInfoText" Text="Select a configuration to view details." TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <!-- Tab 2: Generate New Fit (4-Row Layout) -->
                            <TabItem Header="Create New Fit">
                                <Grid Margin="15,10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <!-- 1. Channel -->
                                        <RowDefinition Height="Auto" />
                                        <!-- 2. Degree -->
                                        <RowDefinition Height="Auto" />
                                        <!-- 3. Actions -->
                                        <RowDefinition Height="Auto" />
                                        <!-- 4. R2 -->
                                    </Grid.RowDefinitions>

                                    <!-- 1. Channel Dropdown -->
                                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                                        <TextBlock Text="Channel Logic" FontWeight="Bold" Margin="0,0,0,4" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <ComboBox x:Name="ChannelFitDropDown" HorizontalAlignment="Stretch" Height="38" FontSize="9">
                                            <ComboBoxItem Content="Single: Red" IsSelected="True" />
                                            <ComboBoxItem Content="Single: Green" />
                                            <ComboBoxItem Content="Single: Blue" />
                                            <ComboBoxItem Content="Dual: Red/Blue" />
                                            <ComboBoxItem Content="Dual: Green/Blue" />
                                            <ComboBoxItem Content="Triple: Red|Green|Blue" />
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- 2. Degree Dropdown -->
                                    <StackPanel Grid.Row="1" Margin="0,0,0,8">
                                        <TextBlock Text="Polynomial Degree" FontWeight="Bold" Margin="0,0,0,4" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <ComboBox x:Name="DegreeFitDropDown" HorizontalAlignment="Stretch" Height="35">
                                            <ComboBoxItem Content="Degree 1" />
                                            <ComboBoxItem Content="Degree 2" />
                                            <ComboBoxItem Content="Degree 3" IsSelected="True" />
                                            <ComboBoxItem Content="Degree 4" />
                                            <ComboBoxItem Content="Degree 5" />
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- 3. Actions (Fit & Save) -->
                                    <Grid Grid.Row="2" Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ui:Button x:Name="FitButton" Content="Calculate Fit" Icon="{ui:SymbolIcon Calculator24}" Grid.Column="0" HorizontalAlignment="Stretch" Margin="0,0,4,0" Height="34" Click="FitButton_Click" Background="{DynamicResource AccentFillColorSecondaryBrush}" Foreground="White"/>
                                        <ui:Button x:Name="SaveButton" Content="Save Config" Icon="{ui:SymbolIcon Save24}" Grid.Column="1" HorizontalAlignment="Stretch" Margin="4,0,0,0" Height="34" Click="SaveButton_Click" />
                                    </Grid>

                                    <!-- 4. R2 Feedback -->
                                    <Border Grid.Row="3" Background="{DynamicResource ControlFillColorSecondaryBrush}" Padding="15,6" CornerRadius="4">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="Goodness of Fit (R²): " VerticalAlignment="Center" />
                                            <TextBlock x:Name="RSquaredText" Text="0.0000" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource AccentFillColorDefaultBrush}" FontSize="14" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </TabItem>
                        </TabControl>

                        <Grid Grid.Row="1" Margin="0,0,0,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <ui:DataGrid x:Name="CalibrationGrid" 
                                         Grid.Row="0"
                                         d:ItemsSource="{d:SampleData ItemCount=5}" 
                                         VerticalAlignment="Stretch"
                                         SelectionMode="Extended"
                                         SelectionChanged="DataGrid_SelectionChanged">
                                <ui:DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Delete Selected" Click="DeleteSelected_Click" Icon="{ui:SymbolIcon Dismiss24}" />
                                    </ContextMenu>
                                </ui:DataGrid.ContextMenu>
                            </ui:DataGrid>
                            
                            <ui:Button x:Name="DeleteRowButton" 
                                       Grid.Row="1" 
                                       Content="Delete Selected Rows" 
                                       Icon="{ui:SymbolIcon Dismiss24}" 
                                       Width="310" 
                                       Margin="0,10,0,0" 
                                       HorizontalAlignment="Center"
                                       Appearance="Secondary" 
                                       Click="DeleteSelected_Click" />
                        </Grid>

                        <Border Grid.Row="2" Grid.RowSpan="2" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="8" Margin="0,0,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Analysis &amp; Calibration Plot" HorizontalAlignment="Center" Margin="5" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                <ScottPlot:WpfPlot x:Name="MainPlot" Grid.Row="1" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Dicom View Tab -->
            <TabItem Header="Dicom View">
                <Grid Margin="12">
                    <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20">Dicom View content placeholder</TextBlock>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Professional Micro-Nav Bar (Footer) -->
        <Border Grid.Row="2" Background="Transparent" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="0,1,0,0" Padding="15,2">
            <Grid>
                <!-- Navigation (Left Aligned) -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <ui:Button x:Name="NavCalibrationButton" 
                              Content="Calibration" 
                              Icon="{ui:SymbolIcon AppGeneric24}" 
                              Width="135" 
                              Height="30" 
                              FontSize="9"
                              VerticalContentAlignment="Center"
                              Margin="0,0,5,0"
                              Appearance="Primary"
                              Click="MenuSelectCalibration_Click" />

                    <ui:Button x:Name="NavDicomButton" 
                              Content="Dicom View" 
                              Icon="{ui:SymbolIcon ImageMultiple24}" 
                              Width="135" 
                              Height="30" 
                              FontSize="9"
                              VerticalContentAlignment="Center"
                              Margin="0,0"
                              Appearance="Secondary"
                              Click="MenuSelectDicom_Click" />
                </StackPanel>

                <!-- Coordinates and Status (Right Aligned) -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="CoordText" Text="0.0, 0.0 mm" Margin="0,0,15,0" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="11" />
                <Border x:Name="StatusIndicator" 
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Center" 
                        Padding="15,4" 
                        Background="#FFFF4500"
                        MinWidth="120">
                    <TextBlock x:Name="StatusText" 
                              Text="Not Ready!" 
                              Foreground="White" 
                              FontWeight="Bold" 
                              FontSize="10"
                              HorizontalAlignment="Center" />
                </Border>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
